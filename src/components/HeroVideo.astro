---
/**
 * HeroVideo — Hero cinématique « pinned » autour de la vidéo produit.
 *
 * Structure : la section fait ~5 écrans de haut. `.hero-sticky` (100svh)
 * reste épinglé pendant que le titre s'estompe, puis 4 chapitres défilent
 * par-dessus la vidéo. En sortie, `.hero-exit-veil` (scrubbé dans
 * animations.js) fond le clip dans le fond charcoal uniforme.
 *
 * Styles : classes .hero-* dans global.css. Seuls la vidéo et le voile de
 * loop sont scoped ici.
 *
 * - autoplay muted loop playsinline + poster fallback
 * - léger fondu noir (.hero-loop-fade) pour masquer la coupure de loop
 * - prefers-reduced-motion : la vidéo reste en pause sur le poster
 */
import type { Lang } from '../i18n/ui';
import { ui } from '../i18n/ui';

interface Props {
  lang?: Lang;
}
const { lang = 'fr' } = Astro.props;
const h = ui[lang].home;
const c = ui[lang].common;
const pad = (n: number) => String(n).padStart(2, '0');
---

<section id="hero" class="hero-section">

  <!-- Écran épinglé : vidéo + titre + veil de sortie -->
  <div class="hero-sticky">

    <!-- Vidéo produit full-bleed -->
    <div class="hero-bg" aria-hidden="true">
      <video
        class="hero-video"
        src="/assets/hero-camera.mp4"
        poster="/assets/hero-camera-poster.jpg"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
      ></video>
      <!-- Voile de transition — masque la coupure du loop -->
      <div class="hero-loop-fade"></div>
    </div>

    <div class="hero-inner">
      <h1 class="gsap-hero-text hero-title">ISO Nord</h1>
      <p class="gsap-hero-text hero-subtitle">{h.heroSubtitle}</p>
    </div>

    <!-- Indicateur de scroll — bas-droite -->
    <div class="hero-scroll-hint" aria-hidden="true">
      <span class="scroll-label">{c.scroll}</span>
      <div class="scroll-line"></div>
    </div>

    <!-- Veil de sortie — fond le clip dans --bg (opacité scrubbée en JS) -->
    <div class="hero-exit-veil" aria-hidden="true"></div>

  </div>

  <!-- Chapitres — défilent par-dessus la vidéo épinglée -->
  <div class="hero-chapters">
    {h.chapters.map((chapter, i) => (
      <div class={`hero-chapter${i % 2 === 1 ? ' hero-chapter--right' : ''}`}>
        <div class="hero-chapter-inner">
          <span class="hero-chapter-num">{pad(i + 1)}</span>
          <h2 class="hero-chapter-title">{chapter.title}</h2>
          <p class="hero-chapter-desc">{chapter.desc}</p>
        </div>
      </div>
    ))}
  </div>

</section>

<style>
  .hero-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transform-origin: center center;
    will-change: transform;
  }

  /* Voile noir — s'opacifie brièvement à la fin du loop pour masquer le saut */
  .hero-loop-fade {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: var(--bg, #141318);
    opacity: 0;
    transition: opacity 0.45s ease;
    pointer-events: none;
  }

  .hero-loop-fade.is-visible {
    opacity: 0.65;
  }
</style>

<script>
  const video = document.querySelector('.hero-video');
  const fade = document.querySelector('.hero-loop-fade');

  if (video instanceof HTMLVideoElement) {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      // Accessibilité : pas de mouvement — le poster reste affiché
      video.autoplay = false;
      video.pause();
    } else {
      // Certains navigateurs bloquent l'autoplay (fenêtre masquée, économie
      // d'énergie…) — on relance dès que les conditions redeviennent bonnes.
      const tryPlay = () => {
        if (video.paused) video.play()?.catch(() => {});
      };
      tryPlay();
      video.addEventListener('canplay', tryPlay);
      document.addEventListener('visibilitychange', () => {
        if (!document.hidden) tryPlay();
      });

      // Micro-fondu noir sur la fenêtre de bouclage (fin + tout début)
      if (fade) {
        const FADE_WINDOW = 0.45; // secondes avant la fin du clip
        video.addEventListener('timeupdate', () => {
          const { duration, currentTime } = video;
          if (!duration) return;
          const nearLoop = duration - currentTime < FADE_WINDOW || currentTime < 0.25;
          fade.classList.toggle('is-visible', nearLoop);
        });
      }
    }
  }
</script>
