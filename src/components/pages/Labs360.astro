---
/**
 * Labs — « Québec en 360 » (labs-360-map).
 *
 * Carte satellite Apple Maps centrée sur les médias publiés à Québec. Un pin
 * ouvre le viewer : panorama équirectangulaire (Pannellum, chargé à la demande),
 * photographie ou clip vidéo. Les données vivent dans src/data/labs360.ts.
 */
import '../../styles/global.css';
import InstrumentHud from '../InstrumentHud.astro';
import LangSwitch from '../LangSwitch.astro';
import { ui, type Lang } from '../../i18n/ui';
import { pathFor, alternates, SITE } from '../../i18n/utils';
import { PLACES, mediaUrl } from '../../data/labs360';
import { hasVisiblePlaces } from '../../scripts/labs360-view.js';

interface Props { lang: Lang }
const { lang } = Astro.props;
const c = ui[lang].common;
const l = ui[lang].labs360;

const canonical = SITE + pathFor('labs360', lang);
const alts = alternates('labs360');
const ogLocale = lang === 'fr' ? 'fr_CA' : 'en_CA';
const navAria = lang === 'fr' ? 'Navigation principale' : 'Main navigation';
const pad = (n: number) => String(n).padStart(2, '0');

const visiblePlaces = PLACES.filter((p) => p.city === 'quebec');
const hasPlaces = hasVisiblePlaces(visiblePlaces);
const featured = visiblePlaces.find((place) => place.featured) ?? visiblePlaces[0];
const socialImage = SITE + featured.preview;
const dateFormatter = new Intl.DateTimeFormat(lang === 'fr' ? 'fr-CA' : 'en-CA', {
  month: 'long',
  year: 'numeric',
  timeZone: 'UTC',
});
const formatCapturedAt = (value: string) =>
  dateFormatter.format(new Date(`${value}-01T12:00:00Z`));

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: l.title,
  description: l.description,
  url: canonical,
  inLanguage: lang === 'fr' ? 'fr-CA' : 'en-CA',
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: visiblePlaces.length,
    itemListElement: visiblePlaces.map((place, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      item: {
        '@type': 'CreativeWork',
        name: place.name,
        description: place.desc[lang],
        contentUrl: mediaUrl(place.media),
        thumbnailUrl: SITE + place.preview,
        spatialCoverage: {
          '@type': 'Place',
          name: place.name,
          geo: {
            '@type': 'GeoCoordinates',
            latitude: place.lat,
            longitude: place.lon,
          },
        },
      },
    })),
  },
};

/* Données runtime pour labs360.js — médias résolus, description de la langue. */
const runtime = {
  lang,
  dragHint: l.dragHint,
  mediaSoon: l.mediaSoon,
  creditPrefix: l.creditPrefix,
  previous: l.previous,
  next: l.next,
  counter: l.counter,
  places: visiblePlaces.map((p) => ({
    id: p.id,
    city: p.city,
    type: p.type,
    name: p.name,
    desc: p.desc[lang],
    credit: p.credit,
    lat: p.lat,
    lon: p.lon,
    media: mediaUrl(p.media),
    preview: p.preview,
    capturedAt: p.capturedAt,
    poster: p.poster ? mediaUrl(p.poster) : '',
  })),
  badge360: l.badge360,
  badgeVideo: l.badgeVideo,
  badgePhoto: l.badgePhoto,
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={l.description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#141318" />
    <link rel="canonical" href={canonical} />
    {alts.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon.png" />
    <link rel="icon" href="/favicon.ico" />
    <title>{l.title}</title>

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ISO Nord" />
    <meta property="og:title" content={l.title} />
    <meta property="og:description" content={l.ogDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:width" content={String(featured.previewWidth)} />
    <meta property="og:image:height" content={String(featured.previewHeight)} />
    <meta property="og:image:alt" content={featured.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={l.title} />
    <meta name="twitter:description" content={l.ogDescription} />
    <meta name="twitter:image" content={socialImage} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@300;400;500&family=Archivo+Expanded:wght@200;300;500&family=Barlow+Condensed:wght@300;400&display=swap" rel="stylesheet" />

  </head>

  <body class="l360-page">

    <a href="#l360-main" class="skip-link">{c.skipLink}</a>

    <InstrumentHud lang={lang} />

    <nav class="l360-nav" aria-label={navAria}>
      <a href={pathFor('home', lang)} class="l360-nav__home">ISO Nord</a>
      <div class="l360-nav__links">
        <a href={pathFor('labs', lang)} class="l360-nav__link">{l.backToLabs}</a>
        <a href={pathFor('portfolio', lang)} class="l360-nav__link l360-nav__portfolio">{c.navPortfolio}</a>
        <LangSwitch lang={lang} page="labs360" class="l360-nav__link" />
      </div>
    </nav>

    <main id="l360-main" tabindex="-1">

      <header class="l360-hero">
        <img
          class="l360-hero__image"
          src={featured.preview}
          width={featured.previewWidth}
          height={featured.previewHeight}
          alt=""
          fetchpriority="high"
          decoding="async"
          aria-hidden="true"
        />
        <div class="l360-hero__shade" aria-hidden="true"></div>
        <div class="l360-inner">
          <div class="l360-hero__content">
            <p class="l360-eyebrow">{l.eyebrow}</p>
            <h1 class="l360-title">{l.titleLines.map((line, i) => (<>{i > 0 && <br />}{line}</>))}</h1>
            <p class="l360-lede">{l.lede}</p>
            <a class="l360-hero__cta" href="#captures">
              <span>{l.exploreCta}</span>
              <span aria-hidden="true">↓</span>
            </a>
            <dl class="l360-hero__stats">
              <div>
                <dt>{l.captureCount}</dt>
                <dd>{pad(visiblePlaces.length)}</dd>
              </div>
              <div>
                <dt>{l.mediaKinds}</dt>
                <dd>{visiblePlaces.filter((place) => place.type === '360').length} × 360° · {visiblePlaces.filter((place) => place.type === 'photo').length} × {l.badgePhoto}</dd>
              </div>
            </dl>
          </div>
        </div>
      </header>

      <section class="l360-map-section">
        <div class="l360-inner">
          <div class="l360-section-head">
            <p class="l360-section-head__eyebrow">{l.mapTitle}</p>
            <p class="l360-section-head__intro">{l.mapIntro}</p>
          </div>

          <!-- Carte satellite Apple Maps (MapKit JS) — remplie par labs360.js -->
          <div class="l360-map" role="region" aria-label={l.mapAria}>
            <div id="l360-mapkit" class="l360-mapkit"></div>
            <p class="l360-map__loading">{l.mapLoading}</p>
            <p class="l360-map__fallback">{l.mapUnavailable}</p>
          </div>

          {!hasPlaces && (
            <p class="l360-empty">{l.mediaSoon}</p>
          )}
        </div>
      </section>

      {hasPlaces && (
        <section class="l360-collection-section" id="captures" aria-labelledby="captures-title">
          <div class="l360-inner">
            <div class="l360-collection-head">
              <p class="l360-eyebrow">{l.collectionEyebrow}</p>
              <h2 id="captures-title">{l.collectionTitle}</h2>
              <p>{l.collectionIntro}</p>
            </div>
            <ol class="l360-collection" aria-label={l.legendAria}>
              {visiblePlaces.map((place, index) => (
                <li class:list={['l360-collection__item', `l360-collection__item--${index + 1}`]}>
                  <button
                    type="button"
                    class="l360-card"
                    data-place-id={place.id}
                    aria-haspopup="dialog"
                    aria-label={`${l.openCapture} — ${place.name}`}
                  >
                    <span class="l360-card__visual">
                      <img
                        src={place.preview}
                        width={place.previewWidth}
                        height={place.previewHeight}
                        alt=""
                        loading="lazy"
                        decoding="async"
                      />
                      <span class="l360-card__index">{pad(index + 1)}</span>
                      <span class="l360-card__open" aria-hidden="true">↗</span>
                    </span>
                    <span class="l360-card__meta">
                      <span class="l360-card__type">
                        {place.type === '360' ? l.badge360 : place.type === 'photo' ? l.badgePhoto : l.badgeVideo}
                      </span>
                      <span class="l360-card__date">{l.captured} · {formatCapturedAt(place.capturedAt)}</span>
                    </span>
                    <strong>{place.name}</strong>
                    <span class="l360-card__desc">{place.desc[lang]}</span>
                  </button>
                </li>
              ))}
            </ol>
            <noscript>
              <p class="l360-noscript">{l.noScript}</p>
            </noscript>
          </div>
        </section>
      )}
    </main>

    <!-- Modal viewer — un seul overlay réutilisé pour 360 et vidéo -->
    <div class="l360-modal" id="l360-modal" role="dialog" aria-modal="true" aria-labelledby="l360-title" aria-describedby="l360-description" hidden>
      <div class="l360-modal__backdrop" data-modal-close></div>
      <div class="l360-modal__panel">
        <button type="button" class="l360-modal__close" data-modal-close aria-label={l.close}>×</button>
        <div class="l360-modal__media" id="l360-media"></div>
        <p class="l360-modal__hint" hidden>{l.dragHint}</p>
        <p class="l360-modal__fallback" hidden>{l.mediaSoon}</p>
        <div class="l360-modal__info">
          <div class="l360-modal__copy">
            <p class="l360-modal__badge"></p>
            <h2 class="l360-modal__name" id="l360-title"></h2>
            <p class="l360-modal__desc" id="l360-description"></p>
            <p class="l360-modal__credit"></p>
          </div>
          <div class="l360-modal__navigation">
            <button type="button" data-view-previous aria-label={l.previous}>←</button>
            <p class="l360-modal__counter" aria-live="polite">01 / {pad(visiblePlaces.length)}</p>
            <button type="button" data-view-next aria-label={l.next}>→</button>
          </div>
        </div>
      </div>
    </div>

    <footer class="l360-footer">
      <div class="l360-inner l360-footer__row">
        <span class="l360-footer__mark">ISO Nord</span>
        <div class="l360-footer__meta">
          <a href={pathFor('labs', lang)}>{l.backToLabs}</a>
          <a href={pathFor('home', lang)}>{l.footerBack}</a>
          <span>{c.copyright}</span>
        </div>
      </div>
    </footer>

    <div class="cursor-dot" aria-hidden="true"></div>
    <div class="cursor-ring" aria-hidden="true"></div>
    <div class="progress-bar" aria-hidden="true"></div>

    <script type="application/json" id="l360-data" set:html={JSON.stringify(runtime)} />
    <script src="../../scripts/labs360.js"></script>

    <style>
      /* Page sombre — tokens globaux du site (bg #141318, accent lime). */
      .l360-page { background: var(--bg); color: var(--text); min-height: 100%; }

      .l360-inner {
        width: 100%;
        max-width: 72rem;
        box-sizing: border-box;
        margin: 0 auto;
        padding: 0 clamp(1.25rem, 5vw, 6rem);
      }

      /* ── Nav (motif labs-nav, en sombre) ── */
      .l360-nav {
        position: absolute;
        top: 0; left: 0; right: 0;
        z-index: 3;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: clamp(1.4rem, 3vw, 2.2rem) clamp(1.25rem, 5vw, 6rem);
      }
      .l360-nav__home, .l360-nav__link, :global(.l360-nav__link) {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 44px;
        min-height: 44px;
        font-family: var(--font-label);
        font-size: 0.66rem;
        letter-spacing: 0.34em;
        text-transform: uppercase;
        color: var(--text);
        transition: color 0.3s ease;
        touch-action: manipulation;
        text-shadow: 0 1px 12px rgba(0, 0, 0, 0.9);
      }
      .l360-nav__link, :global(.l360-nav__link) { color: var(--muted); }
      .l360-nav__links { display: flex; align-items: center; gap: clamp(1.1rem, 3vw, 2rem); }
      .l360-nav__home:hover,
      .l360-nav__link:hover,
      :global(.l360-nav__link:hover) { color: var(--accent); }

      /* ── Hero ── */
      .l360-hero {
        padding: clamp(7rem, 16vh, 10rem) 0 clamp(2rem, 5vw, 3.5rem);
      }
      .l360-eyebrow {
        font-family: var(--font-label);
        font-size: 0.72rem;
        letter-spacing: 0.36em;
        text-transform: uppercase;
        color: var(--dim);
        margin-bottom: var(--s-lg);
      }
      .l360-title {
        font-family: var(--font-display);
        font-weight: 200;
        font-size: clamp(2.6rem, 8vw, 6.2rem);
        text-transform: uppercase;
        line-height: 0.94;
        text-wrap: balance;
      }
      .l360-lede {
        margin-top: var(--s-xl);
        max-width: 40ch;
        font-size: clamp(0.95rem, 1.4vw, 1.1rem);
        line-height: 1.7;
        color: var(--muted);
      }

      /* ── Carte ── */
      .l360-map-section {
        padding-bottom: clamp(5rem, 10vw, 9rem);
      }
      .l360-map {
        position: relative;
        width: 100%;
        min-height: clamp(30rem, 68vh, 48rem);
        aspect-ratio: 4 / 5;               /* mobile-first : carte haute */
        background:
          radial-gradient(120% 90% at 30% 20%, #1a1920 0%, var(--surface) 55%, #121117 100%);
        border: 1px solid var(--border);
        overflow: hidden;
      }
      @media (min-width: 768px) { .l360-map { aspect-ratio: 16 / 10; } }

      /* Conteneur MapKit — rempli par labs360.js. Sous la carte, un message de
         repli reste visible tant que la carte n'a pas chargé (ou si elle échoue). */
      .l360-mapkit { position: absolute; inset: 0; z-index: 1; }
      .l360-map__loading,
      .l360-map__fallback {
        position: absolute; inset: 0; z-index: 0;
        display: grid; place-items: center;
        padding: 2rem; text-align: center;
        font-family: var(--font-label);
        font-size: 0.72rem; letter-spacing: 0.22em; text-transform: uppercase;
        color: var(--dim);
      }
      .l360-map__fallback { display: none; }
      .l360-map[data-state='ready'] .l360-map__loading { display: none; }
      .l360-map[data-state='error'] .l360-mapkit,
      .l360-map[data-state='error'] .l360-map__loading { display: none; }
      .l360-map[data-state='error'] .l360-map__fallback {
        z-index: 2;
        display: grid;
      }
      /* Marqueur lime custom posé sur la carte (annotation MapKit). */
      .l360-marker {
        width: 22px; height: 22px; border-radius: 50%;
        background: var(--accent);
        border: 2px solid #141318;
        box-shadow: 0 0 0 2px color-mix(in oklab, var(--accent) 60%, transparent),
                    0 2px 8px rgba(0,0,0,0.5);
        cursor: pointer;
        display: grid; place-items: center;
        color: #141318; font-size: 11px; font-weight: 700;
        transition: transform 0.2s ease;
      }
      .l360-marker:hover { transform: scale(1.2); }
      .l360-legend__badge,
      .l360-modal__badge {
        font-family: var(--font-label);
        font-size: 0.66rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        font-style: normal;
        color: var(--accent);
      }
      .l360-legend__badge {
        margin-left: 0.5em;
      }

      /* ── Légende ── */
      .l360-legend {
        list-style: none;
        margin: clamp(1.25rem, 3vw, 2rem) 0 0;
        padding: 0;
      }
      .l360-legend__item {
        appearance: none; background: none; border: 0; cursor: pointer;
        display: flex; align-items: baseline; gap: var(--s-md);
        width: 100%;
        min-height: 4rem;
        padding: 0.85rem 0;
        border-top: 1px solid var(--border);
        font-family: var(--font-label);
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--muted);
        transition: color 0.3s ease;
        text-align: left;
        touch-action: manipulation;
      }
      .l360-legend li:last-child .l360-legend__item { border-bottom: 1px solid var(--border); }
      .l360-legend__item:hover { color: var(--text); }
      .l360-legend__item:focus-visible {
        outline: 1px solid var(--accent);
        outline-offset: 4px;
      }
      .l360-legend__num { font-size: 0.66rem; color: var(--dim); }
      .l360-legend__name { font-size: 0.85rem; }
      .l360-empty {
        margin: clamp(1.25rem, 3vw, 2rem) 0 0;
        padding: var(--s-xl);
        border: 1px solid var(--border);
        font-family: var(--font-label);
        font-size: 0.72rem;
        letter-spacing: 0.22em;
        text-align: center;
        text-transform: uppercase;
        color: var(--dim);
      }

      /* ── Atlas cinématographique ── */
      .l360-hero {
        position: relative;
        display: flex;
        align-items: flex-end;
        min-height: 88svh;
        padding: clamp(8rem, 18vh, 11rem) 0 clamp(3rem, 7vw, 5.5rem);
        overflow: hidden;
        isolation: isolate;
      }
      .l360-hero__image,
      .l360-hero__shade {
        position: absolute;
        inset: 0;
      }
      .l360-hero__image {
        z-index: -3;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center 46%;
        scale: 1.015;
      }
      .l360-hero__shade {
        z-index: -2;
        background:
          linear-gradient(90deg, rgba(20, 19, 24, 0.96) 0%, rgba(20, 19, 24, 0.72) 52%, rgba(20, 19, 24, 0.28) 100%),
          linear-gradient(0deg, var(--bg) 0%, transparent 38%);
      }
      .l360-hero__content { max-width: 58rem; }
      .l360-title {
        max-width: 12ch;
        font-size: clamp(3rem, 8.7vw, 7.4rem);
      }
      .l360-lede { max-width: 48ch; }
      .l360-hero__cta {
        display: inline-flex;
        align-items: center;
        justify-content: space-between;
        gap: 2rem;
        min-width: min(100%, 18rem);
        min-height: 48px;
        margin-top: var(--s-xl);
        padding: 0.8rem 1rem;
        border: 1px solid color-mix(in oklab, var(--accent) 58%, transparent);
        font-family: var(--font-label);
        font-size: 0.66rem;
        letter-spacing: 0.24em;
        text-transform: uppercase;
        transition: color 0.3s ease, background 0.3s ease;
      }
      .l360-hero__cta:hover,
      .l360-hero__cta:focus-visible {
        color: var(--bg);
        background: var(--accent);
      }
      .l360-hero__stats {
        display: flex;
        flex-wrap: wrap;
        gap: clamp(2rem, 6vw, 5rem);
        margin-top: clamp(2.5rem, 6vh, 4.5rem);
      }
      .l360-hero__stats div { display: grid; gap: 0.35rem; }
      .l360-hero__stats dt {
        font-family: var(--font-label);
        font-size: 0.6rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--dim);
      }
      .l360-hero__stats dd {
        order: -1;
        font-family: var(--font-display);
        font-size: clamp(1.1rem, 2vw, 1.45rem);
        font-weight: 300;
        text-transform: uppercase;
      }
      .l360-map-section { padding: clamp(4.5rem, 9vw, 8rem) 0; }
      .l360-section-head {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: var(--s-xl);
        margin-bottom: var(--s-xl);
      }
      .l360-section-head__eyebrow {
        font-family: var(--font-label);
        font-size: 0.66rem;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        color: var(--accent);
      }
      .l360-section-head__intro {
        max-width: 38ch;
        color: var(--muted);
        font-size: 0.9rem;
        line-height: 1.6;
      }
      .l360-map { min-height: clamp(24rem, 56vh, 38rem); }
      .l360-collection-section {
        padding: clamp(4rem, 9vw, 8rem) 0;
        border-top: 1px solid var(--border);
      }
      .l360-collection-head {
        display: grid;
        grid-template-columns: minmax(0, 1.4fr) minmax(15rem, 0.6fr);
        column-gap: clamp(2rem, 7vw, 7rem);
        align-items: end;
        margin-bottom: clamp(2.5rem, 6vw, 5rem);
      }
      .l360-collection-head .l360-eyebrow { grid-column: 1 / -1; }
      .l360-collection-head h2 {
        max-width: 12ch;
        font-family: var(--font-display);
        font-size: clamp(2.2rem, 5.8vw, 5rem);
        font-weight: 200;
        line-height: 0.96;
        text-transform: uppercase;
        text-wrap: balance;
      }
      .l360-collection-head > p:last-child {
        max-width: 40ch;
        color: var(--muted);
        line-height: 1.7;
      }
      .l360-collection {
        display: grid;
        grid-template-columns: repeat(12, minmax(0, 1fr));
        gap: clamp(2.5rem, 6vw, 6rem) clamp(1.25rem, 3vw, 2.5rem);
        margin: 0;
        padding: 0;
        list-style: none;
      }
      .l360-collection__item { grid-column: span 6; }
      .l360-collection__item--3,
      .l360-collection__item--6 { grid-column: 3 / span 8; }
      .l360-card {
        width: 100%;
        min-height: 44px;
        padding: 0;
        border: 0;
        background: transparent;
        color: var(--text);
        text-align: left;
        cursor: pointer;
        touch-action: manipulation;
      }
      .l360-card__visual {
        position: relative;
        display: block;
        aspect-ratio: 16 / 10;
        overflow: hidden;
        background: var(--surface);
        border: 1px solid var(--border);
      }
      .l360-card__visual img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: scale 0.7s cubic-bezier(0.2, 0.7, 0.2, 1);
      }
      .l360-card__index,
      .l360-card__open {
        position: absolute;
        top: 1rem;
        display: grid;
        place-items: center;
        min-width: 44px;
        min-height: 44px;
        border: 1px solid rgba(255, 255, 255, 0.28);
        background: rgba(20, 19, 24, 0.72);
        font-family: var(--font-label);
        font-size: 0.64rem;
        color: var(--text);
      }
      .l360-card__index { left: 1rem; }
      .l360-card__open { right: 1rem; font-size: 1rem; }
      .l360-card__meta {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        margin-top: 1rem;
        font-family: var(--font-label);
        font-size: 0.6rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
      }
      .l360-card__type { color: var(--accent); }
      .l360-card__date { color: var(--dim); text-align: right; }
      .l360-card strong {
        display: block;
        margin-top: 0.75rem;
        font-family: var(--font-display);
        font-size: clamp(1.3rem, 2.7vw, 2.3rem);
        font-weight: 300;
        line-height: 1.05;
        text-transform: uppercase;
      }
      .l360-card__desc {
        display: block;
        max-width: 54ch;
        margin-top: 0.65rem;
        color: var(--muted);
        font-size: 0.88rem;
        line-height: 1.6;
      }
      .l360-card:hover .l360-card__visual img,
      .l360-card:focus-visible .l360-card__visual img { scale: 1.035; }
      .l360-card:focus-visible {
        outline: 1px solid var(--accent);
        outline-offset: 6px;
      }
      .l360-noscript {
        margin-top: var(--s-xl);
        padding: 1rem;
        border: 1px solid var(--border);
        color: var(--muted);
      }

      /* ── Modal ── */
      /* user-select: none — le drag du panorama traverse la fiche du lieu
         et surlignerait le texte sans ça. */
      .l360-modal { position: fixed; inset: 0; z-index: 50; user-select: none; }
      .l360-modal__backdrop {
        position: absolute; inset: 0;
        background: color-mix(in oklab, var(--bg) 78%, black);
        opacity: 0.92;
      }
      .l360-modal__panel {
        position: absolute; inset: 0;
        margin: auto;
        width: min(100%, 64rem);
        height: 100%;
        display: flex;
        flex-direction: column;
        background: var(--surface);
        border: 1px solid var(--border);
        overflow: hidden;
      }
      @media (min-width: 768px) {
        .l360-modal__panel { height: min(100%, 44rem); width: min(92vw, 64rem); }
      }
      .l360-modal__close {
        appearance: none; background: color-mix(in oklab, var(--bg) 70%, transparent);
        border: 1px solid var(--border-control);
        color: var(--text);
        position: absolute; top: 0.9rem; right: 0.9rem; z-index: 3;
        width: 44px; height: 44px;
        font-size: 1.4rem; line-height: 1;
        cursor: pointer;
        transition: color 0.3s ease, border-color 0.3s ease;
        touch-action: manipulation;
      }
      .l360-modal__close:hover { color: var(--accent); border-color: var(--accent); }

      .l360-modal__media { position: relative; flex: 1; min-height: 0; background: #0c0b0f; }
      .l360-modal__media :global(video),
      .l360-modal__media :global(.pnlm-container),
      .l360-modal__media :global(img) {
        position: absolute !important; inset: 0;
        width: 100% !important; height: 100% !important;
      }
      .l360-modal__media :global(video) { object-fit: cover; }
      .l360-modal__media :global(img) { object-fit: contain; background: #0c0b0f; }

      .l360-modal__hint {
        position: absolute;
        left: 50%; transform: translateX(-50%);
        bottom: 8.5rem;
        z-index: 2;
        font-family: var(--font-label);
        font-size: 0.66rem;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: var(--text);
        background: color-mix(in oklab, var(--bg) 72%, transparent);
        border: 1px solid var(--border);
        padding: 0.45rem 0.8rem;
        pointer-events: none;
      }
      .l360-modal__fallback {
        position: absolute; inset: 0; z-index: 1;
        display: grid; place-items: center;
        font-family: var(--font-label);
        letter-spacing: 0.24em;
        text-transform: uppercase;
        font-size: 0.75rem;
        color: var(--dim);
      }

      .l360-modal__info {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: var(--s-xl);
        align-items: end;
        padding: var(--s-lg) var(--s-xl) var(--s-xl);
        border-top: 1px solid var(--border);
      }
      .l360-modal__badge { margin-bottom: 0.45rem; }
      .l360-modal__name {
        font-family: var(--font-display);
        font-weight: 200;
        font-size: clamp(1.3rem, 3vw, 2rem);
        text-transform: uppercase;
      }
      .l360-modal__desc {
        margin-top: 0.5rem;
        color: var(--muted);
        font-size: 0.92rem;
        line-height: 1.6;
        max-width: 60ch;
      }
      .l360-modal__credit {
        margin-top: 0.6rem;
        font-family: var(--font-label);
        font-size: 0.66rem;
        letter-spacing: 0.26em;
        text-transform: uppercase;
        color: var(--dim);
      }
      .l360-modal__credit:empty { display: none; }
      .l360-modal__navigation {
        display: grid;
        grid-template-columns: 44px minmax(4.5rem, auto) 44px;
        align-items: center;
        gap: 0.45rem;
      }
      .l360-modal__navigation button {
        appearance: none;
        display: grid;
        place-items: center;
        width: 44px;
        height: 44px;
        border: 1px solid var(--border-control);
        background: transparent;
        color: var(--text);
        cursor: pointer;
        touch-action: manipulation;
      }
      .l360-modal__navigation button:hover,
      .l360-modal__navigation button:focus-visible {
        border-color: var(--accent);
        color: var(--accent);
      }
      .l360-modal__counter {
        font-family: var(--font-label);
        font-size: 0.64rem;
        letter-spacing: 0.18em;
        text-align: center;
        color: var(--dim);
      }

      /* ── Footer (motif labs-footer, en sombre) ── */
      .l360-footer {
        border-top: 1px solid var(--border);
        padding: var(--s-3xl) 0 var(--s-2xl);
        margin-top: var(--s-4xl);
      }
      .l360-footer__row {
        display: flex; justify-content: space-between; align-items: flex-start;
        gap: var(--s-2xl); flex-wrap: wrap;
      }
      .l360-footer__mark {
        font-family: var(--font-label);
        font-size: 0.66rem; letter-spacing: 0.34em; text-transform: uppercase;
      }
      .l360-footer__meta { display: flex; flex-direction: column; align-items: flex-end; gap: 0.5rem; }
      .l360-footer__meta a, .l360-footer__meta span {
        font-family: var(--font-label);
        font-size: 0.6rem; letter-spacing: 0.24em; text-transform: uppercase;
        color: var(--dim);
        transition: color 0.3s ease;
      }
      .l360-footer__meta a {
        display: inline-flex;
        align-items: center;
        min-height: 44px;
        touch-action: manipulation;
      }
      .l360-footer__meta a:hover { color: var(--accent); }

      @media (max-width: 640px) {
        .l360-nav { padding-inline: 0.9rem; }
        .l360-nav__links { gap: 0.6rem; }
        .l360-nav__portfolio { display: none; }
        .l360-nav__home,
        .l360-nav__link,
        :global(.l360-nav__link) {
          font-size: 0.58rem;
          letter-spacing: 0.18em;
          color: var(--text);
        }
        .l360-hero { min-height: 92svh; }
        .l360-hero__shade {
          background:
            linear-gradient(0deg, var(--bg) 0%, rgba(20, 19, 24, 0.58) 55%, rgba(20, 19, 24, 0.75) 100%);
        }
        .l360-section-head { align-items: start; flex-direction: column; }
        .l360-map { min-height: 26rem; height: 56svh; }
        .l360-collection-head { grid-template-columns: 1fr; }
        .l360-collection-head > p:last-child { margin-top: var(--s-lg); }
        .l360-collection { display: block; }
        .l360-collection__item + .l360-collection__item { margin-top: 3rem; }
        .l360-modal__info { grid-template-columns: 1fr; gap: var(--s-md); }
        .l360-modal__navigation { justify-content: end; }
        .l360-footer__row { flex-direction: column; }
        .l360-footer__meta { align-items: flex-start; }
      }

      @media (pointer: coarse) {
        .cursor-dot, .cursor-ring { display: none; }
        .l360-card:hover .l360-card__visual img { scale: 1; }
      }

      @media (prefers-reduced-motion: reduce) {
        .l360-nav__home,
        .l360-nav__link,
        :global(.l360-nav__link),
        .l360-marker,
        .l360-legend__item,
        .l360-hero__cta,
        .l360-card__visual img,
        .l360-modal__close,
        .l360-footer__meta a {
          transition: none;
        }

        .l360-eyebrow,
        .l360-title,
        .l360-lede,
        .l360-map,
        .l360-legend,
        .l360-card {
          opacity: 1;
          transform: none;
        }
      }
    </style>
  </body>
</html>
