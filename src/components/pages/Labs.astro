---
import '../../styles/global.css';
import PetalBloom from '../PetalBloom.astro';
import InstrumentHud from '../InstrumentHud.astro';
import LangSwitch from '../LangSwitch.astro';
import { ui, type Lang } from '../../i18n/ui';
import { pathFor, alternates, SITE } from '../../i18n/utils';

interface Props { lang: Lang }
const { lang } = Astro.props;
const c = ui[lang].common;
const l = ui[lang].labs;

const canonical = SITE + pathFor('labs', lang);
const alts = alternates('labs');
const ogLocale = lang === 'fr' ? 'fr_CA' : 'en_CA';
const navAria = lang === 'fr' ? 'Navigation principale' : 'Main navigation';
const footerAria = lang === 'fr' ? 'Navigation de pied de page' : 'Footer navigation';
const pad = (n: number) => String(n).padStart(2, '0');
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={l.description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#DCE6F2" />
    <link rel="canonical" href={canonical} />
    {alts.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon.png" />
    <link rel="icon" href="/favicon.ico" />
    <title>{l.title}</title>

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ISO Nord" />
    <meta property="og:title" content={l.title} />
    <meta property="og:description" content={l.ogDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={ogLocale} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@300;400;500&family=Archivo+Expanded:wght@200;300;500&family=Barlow+Condensed:wght@300;400&display=swap" rel="stylesheet" />
  </head>

  <body class="labs-page">

    <a href="#labs-main" class="skip-link">{c.skipLink}</a>

    <InstrumentHud light lang={lang} />

    <nav class="labs-nav" aria-label={navAria}>
      <a href={pathFor('home', lang)} class="labs-nav__home">ISO Nord</a>
      <div class="labs-nav__links">
        <a href={pathFor('portfolio', lang)} class="labs-nav__link">{c.navPortfolio}</a>
        <a href={`${pathFor('home', lang)}#labs`} class="labs-nav__link">{l.navLabs}</a>
        <LangSwitch lang={lang} page="labs" class="labs-nav__link" />
      </div>
    </nav>

    <main id="labs-main" tabindex="-1">

      <header class="labs-hero">
        <PetalBloom petals={12} centerX={50} centerY={50} animate={true} />

        <div class="labs-hero__inner">
          <p class="labs-eyebrow">{l.eyebrow}</p>
          <h1 class="labs-title">{l.titleLines.map((line, i) => (<>{i > 0 && <br />}{line}</>))}</h1>
          <p class="labs-lede">{l.lede}</p>
        </div>
      </header>

      <section class="labs-work" aria-label={l.workAria}>
        <div class="labs-inner">
          {l.projects.map((p, i) => (
            <a href={['https://github.com/theodorebeaupre-prog/copad-server', 'https://github.com/theodorebeaupre-prog/garmin-gcd-toolkit', 'https://apps.apple.com/ca/app/iso-nord/id6775643517?l=fr-CA'][i]} target="_blank" rel="noopener noreferrer" class="labs-item">
              <span class="labs-item__num">{pad(i + 1)}</span>
              <div class="labs-item__body">
                <div class="labs-item__head">
                  <h2 class="labs-item__name">
                    {p.name}<span class="sr-only"> {c.openNewTab}</span>
                  </h2>
                  <span class="labs-item__arrow" aria-hidden="true">↗</span>
                </div>
                <p class="labs-item__desc">{p.desc}</p>
                <p class="labs-item__stack">{p.stack}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    </main>

    <footer class="labs-footer">
      <div class="labs-inner labs-footer__row">
        <span class="labs-footer__mark">ISO Nord</span>
        <div class="labs-footer__meta">
          <a href={pathFor('home', lang)}>{l.footerBack}</a>
          <a href="mailto:info@theo-picture.com">info@theo-picture.com</a>
          <span>{c.copyright}</span>
        </div>
      </div>
    </footer>

    <div class="cursor-dot" aria-hidden="true"></div>
    <div class="cursor-ring" aria-hidden="true"></div>
    <div class="progress-bar" aria-hidden="true"></div>

    <script src="../../scripts/labs.js"></script>

    <style>
      /* Palette claire dédiée à Labs — pièce distincte du site studio sombre. */
      .labs-page {
        --ink:        #0A1F5C;   /* bleu nuit — texte principal */
        --ink-soft:   #2B4FC4;   /* bleu royal — accents */
        --ink-muted:  #4d5f8f;   /* corps de texte atténué */
        --ink-dim:    #8090b3;   /* labels, numéros */
        --paper:      #EEF3FA;   /* fond de page hors hero */
        --hairline:   #cdd8ea;   /* filets — ≥3:1 sur --paper */
        min-height: 100%;
        margin: 0;
        background: var(--paper);
        color: var(--ink);
        font-family: var(--font-display);
        font-weight: 300;
        -webkit-font-smoothing: antialiased;
      }

      .labs-inner {
        max-width: 72rem;
        margin: 0 auto;
        padding: 0 clamp(1.5rem, 6vw, 6rem);
      }

      /* ── Nav ── */
      .labs-nav {
        position: absolute;
        top: 0; left: 0; right: 0;
        z-index: 3;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: clamp(1.4rem, 3vw, 2.2rem) clamp(1.5rem, 6vw, 6rem);
      }

      .labs-nav__home,
      .labs-nav__link {
        font-family: var(--font-label);
        font-size: 0.66rem;
        letter-spacing: 0.34em;
        text-transform: uppercase;
        color: var(--ink);
        transition: color 0.3s ease;
      }
      .labs-nav__link { color: var(--ink-soft); }
      .labs-nav__links { display: flex; align-items: center; gap: clamp(1.1rem, 3vw, 2rem); }
      .labs-page .lang-switch { color: var(--ink-dim); }
      .labs-page .lang-switch:hover { color: var(--ink-soft); }
      .labs-nav__home:hover,
      .labs-nav__link:hover { color: var(--ink-soft); opacity: 0.7; }

      /* ── Hero ── */
      .labs-hero {
        position: relative;
        min-height: clamp(30rem, 78vh, 52rem);
        display: flex;
        align-items: center;
        overflow: hidden;
      }

      .labs-hero__inner {
        position: relative;
        z-index: 1;
        max-width: 72rem;
        width: 100%;
        margin: 0 auto;
        padding: 0 clamp(1.5rem, 6vw, 6rem);
      }

      .labs-eyebrow {
        font-family: var(--font-label);
        font-size: 0.72rem;
        letter-spacing: 0.36em;
        text-transform: uppercase;
        color: var(--ink-soft);
        margin-bottom: var(--s-lg);
      }

      .labs-title {
        font-family: var(--font-display);
        font-weight: 300;
        font-size: clamp(2.6rem, 8vw, 6.6rem);
        letter-spacing: 0.01em;
        text-transform: uppercase;
        line-height: 0.94;
        color: var(--ink);
        text-wrap: balance;
      }

      /* Curseur custom sombre (le curseur global est quasi-blanc → invisible ici) */
      .labs-page .cursor-dot { background: color-mix(in oklab, var(--ink) 60%, transparent); }
      .labs-page .cursor-ring { border-color: color-mix(in oklab, var(--ink-soft) 45%, transparent); }
      .labs-page .progress-bar { background: var(--ink-soft); }

      .labs-lede {
        margin-top: var(--s-xl);
        max-width: 34ch;
        font-size: clamp(0.95rem, 1.4vw, 1.15rem);
        line-height: 1.7;
        color: var(--ink-muted);
      }

      /* ── Projets ── */
      .labs-work {
        position: relative;
        z-index: 1;
        background: var(--paper);
        padding: clamp(4rem, 10vw, 8rem) 0 clamp(3rem, 7vw, 5rem);
      }

      .labs-item {
        display: grid;
        grid-template-columns: 4rem 1fr;
        gap: clamp(1rem, 3vw, 2rem);
        align-items: start;
        padding: clamp(1.75rem, 4vw, 2.75rem) 0;
        border-top: 1px solid var(--hairline);
        transition: border-color 0.35s ease;
      }
      .labs-item:last-child { border-bottom: 1px solid var(--hairline); }
      .labs-item:hover { border-color: var(--ink-soft); }

      .labs-item__num {
        font-family: var(--font-label);
        font-size: 0.7rem;
        letter-spacing: 0.2em;
        color: var(--ink-dim);
        padding-top: 0.6em;
        transition: color 0.35s ease;
      }
      .labs-item:hover .labs-item__num { color: var(--ink-soft); }

      .labs-item__body {
        display: flex;
        flex-direction: column;
        gap: var(--s-md);
      }

      .labs-item__head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: var(--s-lg);
      }

      .labs-item__name {
        font-weight: 200;
        font-size: clamp(1.6rem, 3.6vw, 2.9rem);
        letter-spacing: -0.02em;
        line-height: 0.98;
        color: var(--ink);
        transition: color 0.35s ease;
      }
      .labs-item:hover .labs-item__name { color: var(--ink-soft); }

      .labs-item__arrow {
        font-size: 1.15rem;
        color: var(--ink-soft);
        opacity: 0;
        transform: translateX(-10px);
        transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        flex-shrink: 0;
        padding-top: 0.2em;
      }
      .labs-item:hover .labs-item__arrow { opacity: 1; transform: translateX(0); }

      .labs-item__desc {
        font-size: clamp(0.85rem, 1.2vw, 0.95rem);
        line-height: 1.8;
        color: var(--ink-muted);
        max-width: 52ch;
      }

      .labs-item__stack {
        font-family: var(--font-label);
        font-size: 0.66rem;
        letter-spacing: 0.26em;
        text-transform: uppercase;
        color: var(--ink-soft);
      }

      /* ── Footer ── */
      .labs-footer {
        background: var(--paper);
        border-top: 1px solid var(--hairline);
        padding: var(--s-3xl) 0 var(--s-2xl);
      }
      .labs-footer__row {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: var(--s-2xl);
        flex-wrap: wrap;
      }
      .labs-footer__mark {
        font-family: var(--font-label);
        font-size: 0.66rem;
        letter-spacing: 0.34em;
        text-transform: uppercase;
        color: var(--ink);
      }
      .labs-footer__meta {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 0.5rem;
      }
      .labs-footer__meta a,
      .labs-footer__meta span {
        font-family: var(--font-label);
        font-size: 0.6rem;
        letter-spacing: 0.24em;
        text-transform: uppercase;
        color: var(--ink-dim);
      }
      .labs-footer__meta a { transition: color 0.3s ease; }
      .labs-footer__meta a:hover { color: var(--ink-soft); }

      @media (max-width: 640px) {
        .labs-item { grid-template-columns: 2.75rem 1fr; }
        .labs-footer__row { flex-direction: column; }
        .labs-footer__meta { align-items: flex-start; }
      }
    </style>
  </body>
</html>
