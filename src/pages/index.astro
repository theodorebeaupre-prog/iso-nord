---
import '../styles/global.css';
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="ISO Nord — Studio de création visuelle au Québec. Photographie, vidéographie et drone certifié TC." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>ISO Nord — Photography & Drone</title>

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Barlow Condensed — label and numeral contrast only -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@300;400&display=swap" rel="stylesheet" />
  </head>

  <body>

    <!-- ─── Nav ──────────────────────────────────────────────────────────── -->
    <nav class="nav">
      <a href="#" class="nav-wordmark">ISO Nord</a>
      <a href="#contact" class="nav-contact">Contact</a>
    </nav>

    <!-- ─── Hero ─────────────────────────────────────────────────────────── -->
    <!--
      Bottom-anchored layout — title settles in the lower third.
      Inspired by Villeneuve title cards: text at the bottom of the frame,
      darkness above, weight below.
    -->
    <section id="hero" class="hero-section">

      <!-- Coordinate metadata — top-right, like a navigation instrument -->
      <div class="hero-coords" aria-hidden="true">
        <span>46°48′N 71°14′W</span>
        <span>Québec, Canada</span>
      </div>

      <div class="hero-inner">
        <h1 class="gsap-hero-text hero-title">ISO Nord</h1>
        <p class="gsap-hero-text hero-subtitle">Photography &amp; Drone — Québec</p>
      </div>

      <!-- Animated scroll indicator — bottom-right -->
      <div class="hero-scroll-hint" aria-hidden="true">
        <span class="scroll-label">Scroll</span>
        <div class="scroll-line"></div>
      </div>

    </section>

    <!-- ─── Services ──────────────────────────────────────────────────────── -->
    <!--
      Editorial numbered list — not cards.
      Each row is a thin-ruled entry: number / name / description.
      Arrow (→) slides in from left on hover. Accent appears only here.
    -->
    <section id="services" class="services-section">
      <div class="section-inner">

        <div class="gsap-section service-item">
          <span class="service-number">01</span>
          <div class="service-content">
            <div class="service-header">
              <h2 class="service-name">Photographie</h2>
              <span class="service-arrow" aria-hidden="true">→</span>
            </div>
            <p class="service-desc">
              Portraits, événements et espaces — une lumière juste pour chaque moment.
            </p>
          </div>
        </div>

        <div class="gsap-section service-item">
          <span class="service-number">02</span>
          <div class="service-content">
            <div class="service-header">
              <h2 class="service-name">Vidéographie</h2>
              <span class="service-arrow" aria-hidden="true">→</span>
            </div>
            <p class="service-desc">
              Films cinématiques, immobilier et contenu de marque — narration visuelle.
            </p>
          </div>
        </div>

        <div class="gsap-section service-item">
          <span class="service-number">03</span>
          <div class="service-content">
            <div class="service-header">
              <h2 class="service-name">Drone</h2>
              <span class="service-arrow" aria-hidden="true">→</span>
            </div>
            <p class="service-desc">
              Pilote certifié TC — prises de vue aériennes, cartographie et inspections.
            </p>
          </div>
        </div>

      </div>
    </section>

    <!-- ─── Gallery ───────────────────────────────────────────────────────── -->
    <!--
      Alternating editorial grid — 3 columns, explicit row heights.
      Pattern: [wide 2col][narrow 1col] / [narrow 1col][wide 2col] / [wide 2col][narrow 1col]
      Hover reveals dasupply-style metadata: category label + frame number.
      Film grain via CSS SVG feTurbulence on each cell.
    -->
    <section id="gallery" class="gallery-section">

      <div class="gallery-eyebrow">
        <p class="gallery-label">Portfolio</p>
        <span class="gallery-count">006 frames</span>
      </div>

      <div class="gallery-grid">

        <div class="gsap-gallery-item gallery-cell">
          <img src="/assets/gallery/dji_fly_20250421_152710_278_1745273849398_photo_optimized.jpeg" alt="Vue aérienne du Vieux-Québec" style="width:100%; height:100%; object-fit:cover;" />
          <div class="gallery-meta">
            <span class="gallery-meta-cat">Aérien</span>
            <span class="gallery-meta-num">001</span>
          </div>
        </div>

        <div class="gsap-gallery-item gallery-cell">
          <img src="/assets/gallery/C8F52EF9-ACE7-46BD-A134-F08434A5C40A.jpeg" alt="Château Frontenac" style="width:100%; height:100%; object-fit:cover;" />
          <div class="gallery-meta">
            <span class="gallery-meta-cat">Architecture</span>
            <span class="gallery-meta-num">002</span>
          </div>
        </div>

        <div class="gsap-gallery-item gallery-cell">
          <img src="/assets/gallery/_DSC6569.jpeg" alt="Nature, macro" style="width:100%; height:100%; object-fit:cover;" />
          <div class="gallery-meta">
            <span class="gallery-meta-cat">Nature</span>
            <span class="gallery-meta-num">003</span>
          </div>
        </div>

        <div class="gsap-gallery-item gallery-cell">
          <img src="/assets/gallery/20241031-DJI_0177.jpeg" alt="Chutes en automne, vue aérienne" style="width:100%; height:100%; object-fit:cover;" />
          <div class="gallery-meta">
            <span class="gallery-meta-cat">Drone</span>
            <span class="gallery-meta-num">004</span>
          </div>
        </div>

        <div class="gsap-gallery-item gallery-cell">
          <img src="/assets/gallery/_DSC7570.jpeg" alt="Château Frontenac, Québec" style="width:100%; height:100%; object-fit:cover;" />
          <div class="gallery-meta">
            <span class="gallery-meta-cat">Québec</span>
            <span class="gallery-meta-num">005</span>
          </div>
        </div>

        <div class="gsap-gallery-item gallery-cell">
          <img src="/assets/gallery/20260510-_DSC9808.jpeg" alt="Faune, oiseau" style="width:100%; height:100%; object-fit:cover;" />
          <div class="gallery-meta">
            <span class="gallery-meta-cat">Faune</span>
            <span class="gallery-meta-num">006</span>
          </div>
        </div>

      </div>
    </section>

    <!-- ─── About ─────────────────────────────────────────────────────────── -->
    <!--
      Single paragraph at pull-quote scale — reveriesafaris narrative approach.
      Text does all the work; no decorative chrome.
    -->
    <section id="about" class="about-section">
      <div class="section-inner">
        <div class="gsap-section about-block">
          <p class="section-label">À propos</p>
          <p class="about-text">
            ISO Nord est un studio de création visuelle basé au Québec.
            Chaque projet est une exploration de la lumière, du mouvement
            et de l'espace — au sol ou dans les airs.
          </p>
          <p class="about-credential">Pilote certifié TC &nbsp;·&nbsp; Photo &nbsp;·&nbsp; Vidéo &nbsp;·&nbsp; Drone</p>
        </div>
      </div>
    </section>

    <!-- ─── Contact ───────────────────────────────────────────────────────── -->
    <!--
      Contact links are large — they ARE the content.
      Footer carries coordinates as a design detail (dasupply navigation metadata).
    -->
    <section id="contact" class="contact-section">
      <div class="section-inner">
        <div class="gsap-section contact-block">

          <p class="section-label">Contact</p>

          <div class="contact-links">
            <a href="mailto:info@theo-picture.com" class="contact-link">
              info@theo-picture.com
            </a>
            <a
              href="https://instagram.com/iso_nord"
              target="_blank"
              rel="noopener noreferrer"
              class="contact-link"
            >
              @iso_nord
            </a>
          </div>

          <div class="contact-footer">
            <span class="contact-footer-left">46°48′N &nbsp;71°14′W &nbsp;·&nbsp; Québec</span>
            <span class="contact-footer-right">© 2025 ISO Nord</span>
          </div>

        </div>
      </div>
    </section>

    <script src="../scripts/animations.js"></script>

  </body>
</html>

<!-- CODEX: Target .gsap-hero-text, .gsap-section, .gsap-gallery-item for GSAP animations. ScrollTrigger start: top 80%. Hero text delay: 0.3s and 0.8s. Ease: power3.out. translateY from 60px to 0. -->
